"""
Backend .env configuration template
"""
# Database Configuration
DATABASE_URL=postgresql://transactiq:transactiq_dev@localhost:5432/transactiq

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_SQL=false
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Upload Configuration
MAX_UPLOAD_SIZE=5368709120  # 5GB in bytes
CHUNK_SIZE=10000  # rows per chunk

# API Configuration
API_KEY_HEADER=X-API-Key
RATE_LIMIT_ENABLED=false

# Security
SECRET_KEY=your-secret-key-here-change-in-production
HASH_ALGORITHM=bcrypt

# File Storage
UPLOAD_DIR=/tmp/transactiq_uploads
CHUNK_DIR=/tmp/transactiq_chunks

# Validation Rules
PHONE_VALIDATION_ENABLED=true
DATE_VALIDATION_ENABLED=true
DUPLICATE_DETECTION_ENABLED=true
